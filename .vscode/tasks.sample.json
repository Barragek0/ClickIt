{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build and Test",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "Tests\\Scripts\\invoke-build-and-test.ps1",
        "-SolutionPath",
        "ClickIt.sln",
        "-TestProjectPath",
        "Tests\\ClickIt.Tests.csproj",
        "-Configuration",
        "Debug",
        "-ExapiPackagePath",
        "..\\..\\PoeHelper\\net48\\",
        "-PluginOutputPath",
        "C:\\Path\\To\\PoeHelper\\net48\\Plugins\\Compiled\\ClickIt",
        "-BuildTool",
        "msbuild-auto",
        "-IncludeIntegrationTests"
      ],
      "presentation": {
        "reveal": "never"
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Test",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "Tests\\Scripts\\invoke-dotnet-test-with-memory-guard.ps1",
        "-ProjectPath",
        "Tests\\ClickIt.Tests.csproj",
        "-Configuration",
        "Debug",
        "-AdditionalArgs",
        "-p:IncludeIntegrationTests=true"
      ],
      "presentation": {
        "reveal": "never"
      },
      "problemMatcher": [],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    },
    {
      "label": "Review Coverage",
      "type": "process",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "& { & powershell -NoProfile -ExecutionPolicy Bypass -File 'Tests\\Scripts\\generate-coverage.ps1' -configuration 'Debug'; exit $LASTEXITCODE }"
      ],
      "presentation": {
        "reveal": "never",
        "panel": "new"
      },
      "problemMatcher": [],
      "group": {
        "kind": "test",
        "isDefault": false
      }
    }
  ]
}